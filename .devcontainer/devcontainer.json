{
  "name": "R 4.5.3 + RStudio",
  "image": "rocker/rstudio:4.5.3",
  "forwardPorts": [8787],
  "portsAttributes": {
    "8787": {
      "label": "RStudio",
      "onAutoForward": "openBrowser"
    }
  },
  "postStartCommand": "sudo rstudio-server start || true",
  "customizations": {
    "vscode": {
      "extensions": [
        "REditorSupport.r",
        "quarto.quarto"
      ]
    }
  }
}